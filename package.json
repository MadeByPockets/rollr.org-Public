{
  "name": "@mbpockets/shared-ui",
  "version": "0.1.18",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./EventPage": {
      "types": "./dist/EventPage.d.ts",
      "import": "./dist/EventPage.mjs",
      "require": "./dist/EventPage.cjs",
      "default": "./dist/EventPage.mjs"
    },
    "./mocks": {
      "types": "./dist/mocks.d.ts",
      "import": "./dist/mocks.mjs",
      "require": "./dist/mocks.cjs",
      "default": "./dist/mocks.mjs"
    },
    "./PlayerPage": {
      "types": "./dist/PlayerPage.d.ts",
      "import": "./dist/PlayerPage.mjs",
      "require": "./dist/PlayerPage.cjs",
      "default": "./dist/PlayerPage.mjs"
    },
    "./ProfilePage": {
      "types": "./dist/ProfilePage.d.ts",
      "import": "./dist/ProfilePage.mjs",
      "require": "./dist/ProfilePage.cjs",
      "default": "./dist/ProfilePage.mjs"
    },
    "./SearchPage": {
      "types": "./dist/SearchPage.d.ts",
      "import": "./dist/SearchPage.mjs",
      "require": "./dist/SearchPage.cjs",
      "default": "./dist/SearchPage.mjs"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.mjs",
      "require": "./dist/shared.cjs",
      "default": "./dist/shared.mjs"
    },
    "./TablePage": {
      "types": "./dist/TablePage.d.ts",
      "import": "./dist/TablePage.mjs",
      "require": "./dist/TablePage.cjs",
      "default": "./dist/TablePage.mjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs",
      "default": "./dist/types.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "start": "npm run dev",
    "dev": "next dev",
    "build": "node scripts/update-barrels.mjs && tsup && node scripts/fix-use-client.mjs && node scripts/fix-dts-extensions.mjs",
    "prepublishOnly": "npm run build",
    "_release": "node scripts/release.mjs",
    "publish:web": "npm run _release",
    "publish:web:canary": "node scripts/release.mjs --channel canary",
    "publish:web:nightly": "node scripts/release.mjs --channel nightly",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:publish": "node scripts/test-publish.mjs",
    "update:barrels": "node scripts/update-barrels.mjs"
  },
  "peerDependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/icons-material": "^7",
    "@mui/joy": "^5.0.0-beta",
    "@mui/material": "^7",
    "next": "^16.1.6",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "@mui/icons-material": {
      "optional": true
    },
    "@mui/joy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/joy": "^5.0.0-beta.52",
    "@mui/material": "^7.3.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
